# Contact endpoint — email delivery via Gmail SMTP (Nodemailer).
# Sends *as* the Gmail account itself, so the From address is a real gmail.com
# address. Leave unset in dev: submissions are logged to the server console.
#
# Setup: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste the 16 chars (no spaces).
GMAIL_USER=ch.hsyahmedgoheer@gmail.com
GMAIL_APP_PASSWORD=
# Where contact-form notifications are delivered (defaults to GMAIL_USER)
CONTACT_TO_EMAIL=ch.hsyahmedgoheer@gmail.com
# Canonical site URL (used for sitemap / OG)
NEXT_PUBLIC_SITE_URL=https://hasnat.dev
